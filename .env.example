# LIGHT ONE local environment example
# Copy this file to .env only on your local machine.
# Do not commit real secrets, API keys, credentials, or private data paths.

# Runtime mode: development, test, or production
LIGHT_ONE_ENV=development

# Local folders for private experiment data and generated reports
LIGHT_ONE_DATA_DIR=./data
LIGHT_ONE_REPORT_DIR=./reports
LIGHT_ONE_CALIBRATION_DIR=./calibration

# Optional future API settings
# Keep these empty until an API server is actually implemented.
LIGHT_ONE_API_HOST=127.0.0.1
LIGHT_ONE_API_PORT=8000

# Optional future external integrations
# Never paste real keys into tracked files.
EXTERNAL_API_KEY=
